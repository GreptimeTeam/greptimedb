CREATE TABLE range_select_pushdown (
    ts TIMESTAMP TIME INDEX,
    shard STRING,
    series STRING,
    filter_only STRING,
    value_a DOUBLE,
    value_b DOUBLE,
    PRIMARY KEY (shard, series, filter_only),
) PARTITION ON COLUMNS (shard) (
    shard < 'm',
    shard >= 'm'
);

