-- Edge-case coverage for the selected pre-MergeScan optimizer prepass.
-- These cases focus on keeping distributed pushdown safe around subqueries,
-- nullable join keys, deterministic expressions, and nested predicates.
CREATE TABLE fact (
    ts TIMESTAMP(3) TIME INDEX,
    k STRING,
    val DOUBLE,
    `region` STRING,
    PRIMARY KEY (k)
) ENGINE = mito;

Affected Rows: 0

CREATE TABLE dim (
    ts TIMESTAMP(3) TIME INDEX,
    k STRING,
    label STRING,
    PRIMARY KEY (k)
) ENGINE = mito;

Affected Rows: 0

CREATE TABLE vals (
    ts TIMESTAMP(3) TIME INDEX,
    x INT,
    y INT
) ENGINE = mito;

Affected Rows: 0

