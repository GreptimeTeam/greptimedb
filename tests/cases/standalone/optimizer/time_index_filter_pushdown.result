CREATE TABLE
    IF NOT EXISTS `cpu_single` (
        `rack` STRING NULL,
        `usage_small` SMALLINT NULL,
        `greptime_timestamp` TIMESTAMP(9) NOT NULL,
        TIME INDEX (`greptime_timestamp`),
    ) ENGINE = mito
WITH
    (append_mode = 'true', sst_format = 'flat');

