-- The same optimization should work when dropping both b and c from the
-- downstream partitioning requirement.
SELECT a, count(m)
FROM (
  SELECT a, b, c, min(val) AS m
  FROM reduce_aggregate_repartition
  GROUP BY a, b, c
) s
GROUP BY a
ORDER BY a;

+---+------------+
| a | count(s.m) |
+---+------------+
| a | 3          |
| n | 3          |
+---+------------+

