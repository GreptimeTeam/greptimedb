-- Unsafe narrowing and int-to-string roundtrip stay result-correct.
SELECT host, v FROM cast_preimage_int
WHERE CAST(CAST(v AS TINYINT) AS SMALLINT) = v
ORDER BY host;

+-------+---+
| host  | v |
+-------+---+
| host1 | 1 |
| host2 | 2 |
| host3 | 3 |
+-------+---+

