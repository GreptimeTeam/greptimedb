-- Regression test for skip index with column type change.
CREATE TABLE monitoring_data_skip (
    host STRING SKIPPING INDEX,
    `region` STRING,
    cpu_usage DOUBLE SKIPPING INDEX,
    `timestamp` TIMESTAMP TIME INDEX
) WITH ('append_mode'='true');

