| Utf8("2017-07-23 13:10:11") |
+-----------------------------+
| 2017-07-23T13:10:11         |
+-----------------------------+

SELECT timestamp '    2017-07-23 13:10:11    ';

+-----------------------------+
| Utf8("2017-07-23 13:10:11") |
+-----------------------------+
| 2017-07-23T13:10:11         |
+-----------------------------+

