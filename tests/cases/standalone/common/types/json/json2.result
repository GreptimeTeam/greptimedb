create table json2_table
(
    ts timestamp time index,
    j  json2
) with (
    'append_mode' = 'true',
    'sst_format' = 'flat',
);

Affected Rows: 0

insert into json2_table (ts, j)
values (1, '{"a": {"b": 1}, "c": "s1"}'),
       (2, '{"a": {"b": 2}, "c": "s2"}');

Affected Rows: 2

