CREATE TABLE json2_type_hints (
    ts TIMESTAMP TIME INDEX,
    j JSON2 (
        user.age BIGINT NOT NULL DEFAULT 18,
        user.name STRING DEFAULT 'unknown',
        user.active BOOLEAN NULL,
        score DOUBLE NULL DEFAULT 1.5
    )
);

