CREATE TABLE range_select_projection (
    ts TIMESTAMP TIME INDEX,
    station STRING,
    "channel" STRING,
    unused_tag STRING,
    value_a DOUBLE,
    value_b DOUBLE,
    unused_value DOUBLE,
    PRIMARY KEY (station, "channel", unused_tag),
);

