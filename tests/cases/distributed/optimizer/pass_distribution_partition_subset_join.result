CREATE TABLE pd_sub_l(
  ts TIMESTAMP TIME INDEX,
  device_id INTEGER,
  area STRING,
  lv INTEGER,
  PRIMARY KEY(device_id, area)
) PARTITION ON COLUMNS (device_id, area) (
  device_id < 2 AND area < 'm',
  device_id < 2 AND area >= 'm',
  device_id >= 2
) ENGINE=mito;

Affected Rows: 0

CREATE TABLE pd_sub_r(
  ts TIMESTAMP TIME INDEX,
  device_id INTEGER,
  area STRING,
  rv INTEGER,
  PRIMARY KEY(device_id, area)
) PARTITION ON COLUMNS (device_id, area) (
  device_id < 2 AND area < 'm',
  device_id < 2 AND area >= 'm',
  device_id >= 2
) ENGINE=mito;

Affected Rows: 0

