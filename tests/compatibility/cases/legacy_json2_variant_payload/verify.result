SELECT ts, j.a.b AS a_b, j.c AS c
FROM t_legacy_json2_variant_payload
ORDER BY ts;

+---------------------+-----+-----+
| ts                  | a_b | c   |
+---------------------+-----+-----+
| 2026-07-08T00:00:00 | 1   | s1  |
| 2026-07-08T00:01:00 | -2  | [1] |
| 2026-07-08T00:02:00 | s3  | s3  |
| 2026-07-08T00:03:00 |     |     |
| 2026-07-08T00:04:00 |     | s5  |
| 2026-07-08T00:05:00 | 6   |     |
+---------------------+-----+-----+

SELECT ts, j.d AS d
FROM t_legacy_json2_variant_payload
ORDER BY ts;

+---------------------+--------------------+
| ts                  | d                  |
+---------------------+--------------------+
| 2026-07-08T00:00:00 | [{"e":{"f":0.1}}]  |
| 2026-07-08T00:01:00 | [{"e":{"f":0.2}}]  |
| 2026-07-08T00:02:00 | [{"e":{"g":-0.3}}] |
| 2026-07-08T00:03:00 |                    |
| 2026-07-08T00:04:00 | {"e":true}         |
| 2026-07-08T00:05:00 |                    |
+---------------------+--------------------+

SHOW CREATE TABLE t_legacy_json2_variant_payload;

+--------------------------------+---------------------------------------------------------------+
| Table                          | Create Table                                                  |
+--------------------------------+---------------------------------------------------------------+
| t_legacy_json2_variant_payload | CREATE TABLE IF NOT EXISTS "t_legacy_json2_variant_payload" ( |
|                                |   "ts" TIMESTAMP(3) NOT NULL,                                 |
|                                |   "j" JSON2 NULL,                                             |
|                                |   TIME INDEX ("ts")                                           |
|                                | )                                                             |
|                                |                                                               |
|                                | ENGINE=mito                                                   |
|                                | WITH(                                                         |
|                                |   append_mode = 'true'                                        |
|                                | )                                                             |
+--------------------------------+---------------------------------------------------------------+
