SHOW CREATE TABLE t_column_default;

+------------------+-------------------------------------------------+
| Table            | Create Table                                    |
+------------------+-------------------------------------------------+
| t_column_default | CREATE TABLE IF NOT EXISTS "t_column_default" ( |
|                  |   "ts" TIMESTAMP(3) NOT NULL,                   |
|                  |   "host" STRING NULL,                           |
|                  |   "val" INT NULL DEFAULT 42,                    |
|                  |   "msg" STRING NULL DEFAULT 'hello',            |
|                  |   "score" DOUBLE NULL DEFAULT 1.5,              |
|                  |   TIME INDEX ("ts"),                            |
|                  |   PRIMARY KEY ("host")                          |
|                  | )                                               |
|                  |                                                 |
|                  | ENGINE=mito                                     |
|                  |                                                 |
+------------------+-------------------------------------------------+
