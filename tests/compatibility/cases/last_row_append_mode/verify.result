SHOW CREATE TABLE t_last_row_append_mode;

+------------------------+-------------------------------------------------------+
| Table                  | Create Table                                          |
+------------------------+-------------------------------------------------------+
| t_last_row_append_mode | CREATE TABLE IF NOT EXISTS "t_last_row_append_mode" ( |
|                        |   "host" STRING NULL,                                 |
|                        |   "ts" TIMESTAMP(3) NOT NULL,                         |
|                        |   "cpu" DOUBLE NULL,                                  |
|                        |   TIME INDEX ("ts"),                                  |
|                        |   PRIMARY KEY ("host")                                |
|                        | )                                                     |
|                        |                                                       |
|                        | ENGINE=mito                                           |
|                        | WITH(                                                 |
|                        |   append_mode = 'true'                                |
|                        | )                                                     |
+------------------------+-------------------------------------------------------+

