COMMENT ON TABLE compat_comment_table IS 'upgraded table comment';

Affected Rows: 0

COMMENT ON COLUMN compat_comment_table.val IS 'upgraded value column comment';

Affected Rows: 0

COMMENT ON FLOW compat_comment_flow IS 'upgraded flow comment';

