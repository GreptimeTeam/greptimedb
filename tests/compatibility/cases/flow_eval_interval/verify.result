ADMIN FLUSH_FLOW('compat_tql_eval_flow');

+------------------------------------------+
| ADMIN FLUSH_FLOW('compat_tql_eval_flow') |
+------------------------------------------+
|  FLOW_FLUSHED  |
+------------------------------------------+

SELECT count(*) > 0 AS sql_flow_executed
FROM compat_sql_eval_sink;

+-------------------+
| sql_flow_executed |
+-------------------+
| true              |
+-------------------+

SELECT count(*) > 0 AS tql_flow_executed
FROM compat_tql_eval_sink;

+-------------------+
| tql_flow_executed |
+-------------------+
| true              |
+-------------------+
