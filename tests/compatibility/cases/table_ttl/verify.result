SHOW CREATE TABLE t_table_ttl;

+-------------+--------------------------------------------+
| Table       | Create Table                               |
+-------------+--------------------------------------------+
| t_table_ttl | CREATE TABLE IF NOT EXISTS "t_table_ttl" ( |
|             |   "ts" TIMESTAMP(3) NOT NULL,              |
|             |   "host" STRING NULL,                      |
|             |   "val" INT NULL,                          |
|             |   TIME INDEX ("ts"),                       |
|             |   PRIMARY KEY ("host")                     |
|             | )                                          |
|             |                                            |
|             | ENGINE=mito                                |
|             | WITH(                                      |
|             |   ttl = '7days'                            |
|             | )                                          |
+-------------+--------------------------------------------+

ALTER TABLE t_table_ttl SET 'ttl' = '30d';

Affected Rows: 0

